# Dev: reuse the same local Postgres as v2 (schema + seed already applied there).
DATABASE_URL="postgresql://keystone:keystone@localhost:5433/keystone_vendor_dashboard?schema=public"

JWT_ACCESS_SECRET="your-access-secret-here"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_SECRET="your-refresh-secret-here"
JWT_REFRESH_TTL="7d"

APP_URL="http://localhost:3000"

# ── Zoho Books ──
ZOHO_ENABLED="true"
ZOHO_CLIENT_ID=""
ZOHO_CLIENT_SECRET=""
ZOHO_REFRESH_TOKEN=""
ZOHO_ORGANIZATION_ID=""
ZOHO_DC="in"
ZOHO_INVOICE_SOURCE="invoices"

# ── Google Drive ──
DRIVE_ENABLED="true"
DRIVE_CATALOGUES_FOLDER_ID=""
DRIVE_SERVICE_ACCOUNT_JSON=""

# ── Mail ──
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM=""
PO_APPROVER_EMAIL=""
